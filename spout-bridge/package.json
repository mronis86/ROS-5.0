{
  "name": "ros-led-spout",
  "version": "0.1.0",
  "description": "Portable ROS LED Output → Spout bridge for Windows",
  "private": true,
  "main": "electron/main.js",
  "dependencies": {
    "koffi": "^2.9.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "scripts": {
    "start": "electron .",
    "bake": "electron scripts/bake-led-prerenders.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.sinor.ros.ledspout",
    "productName": "ROS LED Spout",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/",
        "to": "vendor",
        "filter": [
          "SpoutLibrary.dll"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ROS-LED-Spout-${version}-portable.exe"
    }
  }
}
