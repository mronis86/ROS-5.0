# Environment Configuration Example
# Copy this to .env.local for local development

# ===========================================
# VITE/REACT CONFIGURATION (Frontend)
# ===========================================
VITE_API_BASE_URL=http://localhost:3001
# For Railway deployment: VITE_API_BASE_URL=https://your-app.railway.app

# ===========================================
# NEON AUTH (recommended for web app users)
# ===========================================
# Enable Auth in Neon Console → copy Auth URL from Configuration tab
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth
# Railway API — same URL without VITE_ prefix (for JWT verification + server-side sign-in)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth
# Optional: fallback Origin when Railway proxies Neon Auth (defaults to http://localhost:3003)
# NEON_AUTH_CLIENT_ORIGIN=https://your-site.netlify.app

# Optional: Neon Management API — removes users from Neon Console Auth → Users on admin delete
# Create an API key at https://console.neon.tech/app/settings/api-keys
# NEON_API_KEY=neon_api_...
# NEON_PROJECT_ID=your-project-id
# NEON_BRANCH_ID=br-...   # optional; primary branch is used when omitted

# Legacy Stack Auth (deprecated — migrate to VITE_NEON_AUTH_URL above)
# VITE_STACK_PROJECT_ID=your_neon_auth_project_id
# VITE_STACK_PUBLISHABLE_CLIENT_KEY=your_neon_auth_publishable_key

# ===========================================
# DATABASE CONFIGURATION (Backend)
# ===========================================
DATABASE_URL=postgresql://username:password@host:port/database
# Railway handles this automatically

# ===========================================
# API AUTH ENFORCEMENT (Railway only)
# ===========================================
# none = open API (default). writes = POST/PUT/DELETE need a token. all = every /api call needs a token.
# Start with writes after Companion has an integration token (Admin → Integration API tokens).
REQUIRE_API_AUTH=writes
# Do not set to true when REQUIRE_API_AUTH is writes or all (would bypass enforcement).
# ALLOW_LEGACY_PUBLIC_API=false

# Auth brute-force protection (Railway production). Disabled in local dev unless AUTH_RATE_LIMIT_DISABLED=false.
# AUTH_RATE_LIMIT_DISABLED=false
# AUTH_RATE_LIMIT_LOGIN_MAX=8
# AUTH_RATE_LIMIT_LOGIN_WINDOW_MIN=15
# AUTH_RATE_LIMIT_LOGIN_WARNING_AFTER=5
# AUTH_RATE_LIMIT_PUBLIC_MAX=20
# AUTH_RATE_LIMIT_PUBLIC_WINDOW_MIN=60

# Admin ops alerts (Railway production). Emails admins on API 500s and security events.
# Uses the same RESEND_API_KEY and ADMIN_NOTIFY_FROM as access-request emails.
# OPS_ALERTS_DISABLED=false
# OPS_ALERT_API_ERROR_MIN_STATUS=500
# OPS_ALERT_API_ERROR_COOLDOWN_MIN=15
# OPS_ALERT_SECURITY_COOLDOWN_MIN=15
# OPS_ALERT_UNAUTHORIZED_API_MAX=10
# OPS_ALERT_UNAUTHORIZED_API_WINDOW_MIN=15
# USER_REPORT_RATE_LIMIT_MAX=10
# USER_REPORT_RATE_LIMIT_WINDOW_MIN=60
# USER_REPORT_ALERT_COOLDOWN_MIN=15
# USER_REPORT_CONSOLE_LOG_MAX_CHARS=12000

# Admin email notifications (Resend)
# RESEND_API_KEY=re_...
# Testing only — delivers to your Resend account email, not all admins:
# ADMIN_NOTIFY_FROM="Run of Show <onboarding@resend.dev>"
# Production — use an address on your verified Resend domain:
# ADMIN_NOTIFY_FROM="Run of Show <noreply@yourdomain.com>"

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
NODE_ENV=development
# Railway production: NODE_ENV=production (enables Socket.IO allowlist + ops alerts)
# Optional extra Socket.IO origins (comma-separated), e.g. custom domain:
# SOCKET_CORS_ORIGINS=https://www.yourdomain.com
# Node: Railway uses nixpacks.toml NIXPACKS_NODE_VERSION=22.20.0 (also .nvmrc / package.json engines)
# Platform maintenance emails (Review/Urgent) — requires production + Resend; optional:
# Defaults: check weekly, email at most once per week for the same open issues
# PLATFORM_MAINTENANCE_ALERT_COOLDOWN_HOURS=168
# PLATFORM_MAINTENANCE_ALERT_INTERVAL_HOURS=168
# PLATFORM_MAINTENANCE_ALERTS_DISABLED=true

