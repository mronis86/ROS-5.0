# Environment Configuration Example
# Copy this to .env.local for local development

# ===========================================
# VITE/REACT CONFIGURATION (Frontend)
# ===========================================
VITE_API_BASE_URL=http://localhost:3001
# For Railway deployment: VITE_API_BASE_URL=https://your-app.railway.app

# ===========================================
# NEON AUTH (recommended for web app users)
# ===========================================
# Enable Auth in Neon Console → copy Auth URL from Configuration tab
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth
# Railway API — same URL without VITE_ prefix (for JWT verification + server-side sign-in)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth
# Optional: fallback Origin when Railway proxies Neon Auth (defaults to http://localhost:3003)
# NEON_AUTH_CLIENT_ORIGIN=https://your-site.netlify.app

# Legacy Stack Auth (deprecated — migrate to VITE_NEON_AUTH_URL above)
# VITE_STACK_PROJECT_ID=your_neon_auth_project_id
# VITE_STACK_PUBLISHABLE_CLIENT_KEY=your_neon_auth_publishable_key

# ===========================================
# DATABASE CONFIGURATION (Backend)
# ===========================================
DATABASE_URL=postgresql://username:password@host:port/database
# Railway handles this automatically

# ===========================================
# API AUTH ENFORCEMENT (Railway only)
# ===========================================
# none = open API (default). writes = POST/PUT/DELETE need a token. all = every /api call needs a token.
# Start with writes after Companion has an integration token (Admin → Integration API tokens).
REQUIRE_API_AUTH=writes
# Do not set to true when REQUIRE_API_AUTH is writes or all (would bypass enforcement).
# ALLOW_LEGACY_PUBLIC_API=false

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
NODE_ENV=development

